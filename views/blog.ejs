<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
        <title>
            <%= blog.title %>
        </title>
</head>

<body>
    <%- include('./partials/nav') %>

        <div class="container mt-4">

            <img src="<%= blog.coverImageURL %>" class="img-fluid mb-3" alt="Blog Image">

            <h1>
                <%= blog.title %>
            </h1>

            <p class="text-muted">
                Created by <%= blog.createdBy.fullName %>
            </p>

            <hr>

            <pre class="mt-4">
            <%= blog.body %>
        </pre>
        </div>
        <div class="container mt-4">
            <img src="<%= blog.createdBy.profileImage %>" width="50" height="50" alt="Profile Image">

            <span class="ms-2">
                <%= blog.createdBy.fullName %>
            </span>
        </div>

        <div class="container mt-3">
            <h1>Comments (<%= (comments.length)%>) </h1>
            <% if (locals.user) { %>
                <div class="container mt-4">
                    <form action="/blog/comment/<%= blog._id %>" method="POST">

                        <div class="mb-3">

                            <input type="text" name="content" class="form-control" placeholder="Enter your Comment">
                            <button class="btn btn-sn btn-primary mt-2" type="submit">ADD</button>
                        </div>

                    </form>
                </div>
                <% } %>
                <div class="mt-3">
                    <% comments.forEach(comment=> { %>
                        <div>
                            <img src="<%= comment.createdBy.profileImage %>" width="50" height="50" alt="Profile Image">

                            <%= comment.createdBy.fullName %>:

                                <pre><%= comment.content %></pre>
                        </div>
                        <% }) %>
                </div>
        </div>
        <%- include('./partials/scripts') %>
</body>

</html>