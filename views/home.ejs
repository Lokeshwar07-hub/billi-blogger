<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
    <title>Home Page</title>
</head>

<body>
    <%- include('./partials/nav') %>

    <div class="container mt-3">
        <div class="row g-3">

            <% blogs.forEach(blog => { %>
                <div class="col-md-3">
                    <div class="card h-100">

                        <img
                            src="<%= blog.coverImageURL %>"
                            class="card-img-top"
                            alt="Blog Image"
                        >

                        <div class="card-body">
                            <h5 class="card-title">
                                <%= blog.title %>
                            </h5>

                            <a href="/blog/<%= blog._id %>" class="btn btn-primary">
                                Read More
                            </a>
                        </div>

                    </div>
                </div>
            <% }) %>

        </div>
    </div>

    <%- include('./partials/scripts') %>
</body>

</html>